{
  "version": 2,
  "functions": {
    "api/create-payment-intent.js": {
      "memory": 128
    }
  },
  "routes": [
    {"source": "/api/(.*)", "destination": "/api/$1"},
    {"source": "/thank-you", "destination": "/pages/thank-you.html"},
    {"source": "/members", "destination": "/pages/members.html"},
    {"source": "/bonuses/proposals", "destination": "/pages/bonuses/proposals.html"},
    {"source": "/bonuses/objections", "destination": "/pages/bonuses/objections.html"},
    {"source": "/bonuses", "destination": "/pages/bonuses/index.html"},
    {"source": "/deliverables/templates", "destination": "/pages/deliverables/templates.html"},
    {"source": "/deliverables/scripts", "destination": "/pages/deliverables/scripts.html"},
    {"source": "/deliverables/pricing", "destination": "/pages/deliverables/pricing.html"},
    {"source": "/deliverables/tools", "destination": "/pages/deliverables/tools.html"},
    {"source": "/vsl", "destination": "/pages/vsl-player.html"},
    {"source": "/vsl-player-embed.html", "destination": "/pages/vsl-player-embed.html"},
    {"source": "/checkout", "destination": "/pages/checkout.html"},
    {"source": "/free-tools/agency-plan", "destination": "/pages/free-tools/agency-plan.html"},
    {"source": "/free-tools/income-simulator", "destination": "/pages/free-tools/income-simulator.html"},
    {"source": "/pages/(.*)", "destination": "/pages/$1"},
    {"source": "/robots.txt", "destination": "/robots.txt"},
    {"source": "/sitemap.xml", "destination": "/sitemap.xml"},
    {"source": "/(.*)", "destination": "/index.html"}
  ]
}
